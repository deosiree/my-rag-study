CUSTOM_API_KEY=
CUSTOM_BASE_URL=
CUSTOM_MODEL_NAME=

# --- 可选：官方 OpenAI ---
OPENAI_API_KEY=

# --- 可选：LangSmith / LangChain 观测与 LangGraph 云端 ---
LANGSMITH_API_KEY=
LANGCHAIN_API_KEY=
LANGGRAPH_API_KEY=

